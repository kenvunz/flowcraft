{
	"name": "@flowcraft/cli",
	"type": "module",
	"version": "1.0.0-beta.0",
	"description": "Command-line interface for Flowcraft workflow observability and debugging",
	"bin": {
		"flowcraft": "./dist/index.js"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest run"
	},
	"dependencies": {
		"@flowcraft/postgres-history": "1.0.0-beta.0",
		"@flowcraft/sqlite-history": "1.0.0-beta.0",
		"chalk": "^5.6.2",
		"commander": "^14.0.3",
		"flowcraft": "^2.8.1",
		"ora": "^9.3.0",
		"table": "^6.9.0"
	},
	"devDependencies": {
		"@types/node": "^25.5.0",
		"tsdown": "^0.21.7",
		"typescript": "^6.0.2",
		"vitest": "^4.1.2"
	}
}
