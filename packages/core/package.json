{
	"name": "flowcraft",
	"type": "module",
	"version": "2.8.1",
	"description": "A lightweight workflow engine",
	"license": "MIT",
	"homepage": "https://flowcraft.js.org",
	"repository": {
		"type": "git",
		"url": "https://github.com/gorango/flowcraft.git"
	},
	"bugs": "https://github.com/gorango/flowcraft/issues",
	"keywords": [
		"agentic-workflows",
		"ai-agent",
		"background-jobs",
		"dag",
		"data-pipelines",
		"declarative-workflows",
		"distributed-systems",
		"etl",
		"llm-orchestration",
		"orchestration",
		"rag",
		"state-machine",
		"workflow-engine"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs"
		},
		"./sdk": {
			"types": "./dist/sdk.d.mts",
			"import": "./dist/sdk.mjs"
		},
		"./testing": {
			"types": "./dist/testing/index.d.mts",
			"import": "./dist/testing/index.mjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"dev": "tsdown --watch",
		"build": "tsdown",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage"
	},
	"devDependencies": {
		"@types/node": "^25.5.0",
		"@vitest/coverage-v8": "4.0.4",
		"tsdown": "^0.21.7",
		"typescript": "^6.0.2",
		"vitest": "^4.1.2"
	}
}
