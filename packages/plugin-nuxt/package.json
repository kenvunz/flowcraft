{
	"name": "@flowcraft/nuxt-module",
	"version": "1.0.0-alpha.2",
	"description": "Nuxt module for Flowcraft compiler integration",
	"keywords": [
		"build",
		"flowcraft",
		"module",
		"nuxt",
		"nuxtjs",
		"workflow"
	],
	"homepage": "https://flowcraft.js.org",
	"bugs": "https://github.com/gorango/flowcraft/issues",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/gorango/flowcraft.git"
	},
	"files": [
		"dist"
	],
	"type": "commonjs",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"require": "./dist/index.cjs"
		}
	},
	"scripts": {
		"dev": "tsdown --watch --config-loader unrun",
		"build": "tsdown --config-loader unrun",
		"typecheck": "tsc --noEmit",
		"test": "echo \"Error: no test specified\" && exit 0"
	},
	"dependencies": {
		"@flowcraft/vite-plugin": "1.0.0-alpha.2"
	},
	"devDependencies": {
		"@flowcraft/compiler": "1.0.0-alpha.2",
		"@nuxt/kit": "^4.4.2",
		"@types/node": "^25.5.0",
		"tsdown": "^0.21.7"
	},
	"peerDependencies": {
		"@nuxt/kit": "^3.0.0",
		"nuxt": "^3.0.0"
	}
}
