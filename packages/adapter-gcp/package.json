{
	"name": "@flowcraft/gcp-adapter",
	"version": "1.5.1",
	"homepage": "https://flowcraft.js.org",
	"files": [
		"dist"
	],
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs"
		}
	},
	"scripts": {
		"build": "tsdown src/index.ts --format esm --dts",
		"test": "./testcontainers.sh && vitest run src/*.test.ts",
		"test:coverage": "./testcontainers.sh && vitest run src/*.test.ts --coverage",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@google-cloud/firestore": "^8.3.0",
		"@google-cloud/pubsub": "^5.3.0",
		"flowcraft": "^2.10.1",
		"ioredis": "^5.10.1"
	},
	"devDependencies": {
		"@testcontainers/gcloud": "^11.14.0",
		"@testcontainers/redis": "^11.14.0",
		"@vitest/coverage-v8": "^4.1.4",
		"testcontainers": "^11.14.0",
		"tsdown": "^0.21.7",
		"typescript": "^6.0.2",
		"vitest": "^4.1.4"
	}
}
