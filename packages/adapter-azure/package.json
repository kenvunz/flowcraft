{
	"name": "@flowcraft/azure-adapter",
	"version": "1.5.0",
	"homepage": "https://flowcraft.js.org",
	"files": [
		"dist"
	],
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs"
		}
	},
	"scripts": {
		"build": "tsdown src/index.ts --format esm --dts",
		"test": "./testcontainers.sh && vitest run src/*.test.ts",
		"test:coverage": "./testcontainers.sh && vitest run src/*.test.ts --coverage",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@azure/cosmos": "^4.9.2",
		"@azure/storage-queue": "^12.29.0",
		"flowcraft": "^2.10.0",
		"ioredis": "^5.10.1"
	},
	"devDependencies": {
		"@testcontainers/azurite": "^11.14.0",
		"@testcontainers/redis": "^11.14.0",
		"@vitest/coverage-v8": "^4.1.4",
		"testcontainers": "^11.14.0",
		"tsdown": "^0.21.7",
		"typescript": "^6.0.2",
		"vitest": "^4.1.4"
	}
}
