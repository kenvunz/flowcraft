{
	"name": "@flowcraft/next-plugin",
	"type": "commonjs",
	"version": "1.0.0-alpha.1",
	"description": "Next.js plugin for Flowcraft compiler integration",
	"license": "MIT",
	"homepage": "https://flowcraft.js.org",
	"repository": {
		"type": "git",
		"url": "https://github.com/gorango/flowcraft.git"
	},
	"bugs": "https://github.com/gorango/flowcraft/issues",
	"keywords": [
		"flowcraft",
		"nextjs",
		"next",
		"plugin",
		"build",
		"workflow"
	],
	"exports": {
		".": {
			"require": "./dist/index.cjs",
			"types": "./dist/index.d.cts"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"dev": "tsdown --watch",
		"build": "tsdown",
		"typecheck": "tsc --noEmit",
		"test": "echo \"Error: no test specified\" && exit 0"
	},
	"dependencies": {
		"@flowcraft/compiler": "1.0.0-alpha.1"
	},
	"devDependencies": {
		"@types/node": "^25.5.0",
		"tsdown": "^0.21.7"
	},
	"peerDependencies": {
		"next": "^13.0.0 || ^14.0.0 || ^15.0.0"
	}
}
