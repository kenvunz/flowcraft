{
	"name": "@flowcraft/opentelemetry-middleware",
	"version": "1.0.2",
	"description": "OpenTelemetry middleware for Flowcraft workflows",
	"homepage": "https://flowcraft.js.org",
	"files": [
		"dist"
	],
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs"
		}
	},
	"scripts": {
		"build": "tsdown src/index.ts --format esm --dts",
		"test": "vitest run",
		"typecheck": "tsc --noEmit"
	},
	"devDependencies": {
		"@opentelemetry/sdk-trace-base": "^2.6.1",
		"@types/node": "^25.5.0",
		"tsdown": "^0.21.7",
		"typescript": "^6.0.2",
		"vitest": "^4.1.2"
	},
	"peerDependencies": {
		"@opentelemetry/api": "^1.8.0",
		"flowcraft": "^2.8.1"
	}
}
