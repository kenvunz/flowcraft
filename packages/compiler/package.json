{
	"name": "@flowcraft/compiler",
	"version": "1.0.0-alpha.2",
	"description": "A compiler for transforming imperative TypeScript into declarative Flowcraft workflows",
	"keywords": [
		"compiler",
		"flowcraft",
		"typescript",
		"workflow"
	],
	"homepage": "https://flowcraft.js.org",
	"bugs": "https://github.com/gorango/flowcraft/issues",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/gorango/flowcraft.git"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs"
		}
	},
	"scripts": {
		"dev": "tsdown --watch",
		"build": "tsdown",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage"
	},
	"dependencies": {
		"esbuild": "^0.28.0",
		"flowcraft": "^2.10.0",
		"resolve": "^1.22.12",
		"typescript": "^6.0.2"
	},
	"devDependencies": {
		"@types/node": "^25.6.0",
		"@types/resolve": "^1.20.6",
		"@vitest/coverage-v8": "^4.1.4",
		"tsdown": "^0.21.7",
		"vitest": "^4.1.4"
	}
}
