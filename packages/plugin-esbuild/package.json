{
	"name": "@flowcraft/esbuild-plugin",
	"type": "module",
	"version": "1.0.0-alpha.2",
	"description": "esbuild plugin for Flowcraft compiler integration",
	"license": "MIT",
	"homepage": "https://flowcraft.js.org",
	"repository": {
		"type": "git",
		"url": "https://github.com/gorango/flowcraft.git"
	},
	"bugs": "https://github.com/gorango/flowcraft/issues",
	"keywords": [
		"flowcraft",
		"esbuild",
		"plugin",
		"build",
		"workflow"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"dev": "tsdown --watch",
		"build": "tsdown",
		"typecheck": "tsc --noEmit",
		"test": "echo \"Error: no test specified\" && exit 0"
	},
	"dependencies": {
		"@flowcraft/compiler": "1.0.0-alpha.1"
	},
	"devDependencies": {
		"@types/node": "^25.5.0",
		"esbuild": "^0.27.4",
		"tsdown": "^0.21.7"
	},
	"peerDependencies": {
		"esbuild": "^0.15.0 || ^0.16.0 || ^0.17.0 || ^0.18.0 || ^0.19.0"
	}
}
